{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "LANES: Backend",
            "type": "shell",
            "command": ".\\venv\\Scripts\\uvicorn.exe",
            "args": ["app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "presentation": {
                "group": "lanes-dev",
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "LANES: Frontend",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "presentation": {
                "group": "lanes-dev",
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start LANES Dev Server",
            "dependsOn": [
                "LANES: Backend",
                "LANES: Frontend"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
